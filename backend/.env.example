# ── Core ──
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
JWT_SECRET=<generate-a-random-secret>
# CLIENT_URL=http://localhost:5173
CLIENT_URL=https://a-realtime-project-planning-and-col.vercel.app

# ── AI Providers ──
# Primary: ollama (local, free) — make sure ollama is running on localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Cloud fallbacks (get free keys from their respective dashboards)
MISTRAL_API_KEY=
MISTRAL_API_KEY_CODING=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-large-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Which provider to use: ollama | mistral | gemini
AI_PROVIDER=mistral

# ── GitHub OAuth ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/github/callback
GITHUB_WEBHOOK_SECRET=
