  "backend": {
    "models": [
      {
        "name": "User",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "role",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "date",
            "required": true
          }
        ],
        "relationships": []
      },
      {
        "name": "Project",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "required": true
          },
          {
            "name": "dueDate",
            "type": "date",
            "required": true
          }
        ],
        "relationships": [
          {
            "name": "members",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      {
        "name": "Task",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "required": true
          },
          {
            "name": "assigneeId",
            "type": "string",
            "required": false
          }
        ],
        "relationships": [
          {
            "name": "projectId",
            "type": "string",
            "required": true
          }
        ]
      }
    ],
    "controllers": [
      {
        "name": "UserController",
        "methods": [
          "list",
          "create",
          "update",
          "delete"
        ],
        "routes": [
          {
            "method": "GET",
            "path": "/api/users"
          },
          {
            "method": "POST",
            "path": "/api/users"
          },
          {
            "method": "PUT",
            "path": "/api/users/:id"
          },
          {
            "method": "DELETE",
            "path": "/api/users/:id"
          }
        ]
      },
      {
        "name": "ProjectController",
        "methods": [
          "list",
          "create",
          "update",
          "delete",
          "addMember"
        ],
        "routes": [
          {
            "method": "GET",
            "path": "/api/projects"
          },
          {
            "method": "POST",
            "path": "/api/projects"
          },
          {
            "method": "PUT",
            "path": "/api/projects/:id"
          },
          {
            "method": "DELETE",
            "path": "/api/projects/:id"
          },
          {
            "method": "POST",
            "path": "/api/projects/:id/members"
          }
        ]
      },
      {
        "name": "TaskController",
        "methods": [
          "list",
          "create",
          "update",
          "delete",
          "assignTo",
          "addComment"
        ],
        "routes": [
          {
            "method": "GET",
            "path": "/api/tasks"
          },
          {
            "method": "POST",
            "path": "/api/tasks"
          },
          {
            "method": "PUT",
            "path": "/api/tasks/:id"
          },
          {
            "method": "DELETE",
            "path": "/api/tasks/:id"
          },
          {
            "method": "POST",
            "path": "/api/tasks/:id/assign"
          },
          {
            "method": "POST",
            "path": "/api/tasks/:id/comments"
          }
        ]
      }
    ],
    "services": [
      {
        "name": "UserService",
        "methods": [
          "getUsers",
          "createUser",
          "updateUser",
          "deleteUser"
        ]
      },
      {
        "name": "ProjectService",
        "methods": [
          "getProjects",
          "createProject",
          "updateProject",
          "deleteProject",
          "addMember"
        ]
      },
      {
        "name": "TaskService",
        "methods": [
          "getTasks",
          "createTask",
          "updateTask",
          "deleteTask",
          "assignTo",
          "addComment"
        ]
      }
    ],
    "middleware": [
      "auth",
      "validation"
    ]
  },
  "frontend": {
    "components": [
      {
        "name": "UserList",
        "props": [
          "users",
          "onEdit",
          "onDelete"
        ],
        "state": []
      },
      {
        "name": "ProjectList",
        "props": [
          "projects",
          "onEdit",
          "onDelete"
        ],
        "state": []
      },
      {
        "name": "TaskList",
        "props": [
          "tasks",
          "onEdit",
          "onDelete"
        ],
        "state": []
      },
      {
        "name": "UserForm",
        "props": [
          "user",
          "onSubmit",
          "onCancel"
        ],
        "state": [
          "formData"
        ]
      },
      {
        "name": "ProjectForm",
        "props": [
          "project",
          "onSubmit",
          "onCancel"
        ],
        "state": [
          "formData"
        ]
      },
      {
        "name": "TaskForm",
        "props": [
          "task",
          "onSubmit",
          "onCancel"
        ],
        "state": [
          "formData"
        ]
      }
    ],
    "pages": [
      {
        "name": "HomePage",
        "route": "/"
      },
      {
        "name": "UserPage",
        "route": "/users"
      },
      {
        "name": "ProjectPage",
        "route": "/projects"
      },
      {
        "name": "TaskPage",
        "route": "/tasks"
      }
    ],
    "hooks": [
      "useApi"
    ],
    "services": [
      "api"
    ]
  },
  "database": {
    "type": "mongodb",
    "collections": [
      {
        "name": "users",
        "schema": "User model schema"
      },
      {
        "name": "projects",
        "schema": "Project model schema"
      },
      {
        "name": "tasks",
        "schema": "Task model schema"
      }
    ]
  },
